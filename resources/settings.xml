<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings version="1">
    <section id="script.service.flaresolverr">
        <category id="1" label="30000">
            <group id="1">
                <setting id="host" type="string" label="30001">
                    <level>0</level>
                    <default>0.0.0.0</default>
                    <control type="edit" format="string"/>
                </setting>
                <setting id="port" type="integer" label="30002">
                    <level>0</level>
                    <default>8191</default>
                    <control type="edit" format="integer"/>
                </setting>
                <setting id="headless" type="boolean" label="30003">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
            </group>
        </category>
        <category id="2" label="Advanced">
            <group id="1">
                <setting id="enable_log" type="boolean" label="Enable Debug Logging">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="enable_remote_log_viewer" type="boolean" label="Enable Remote Log Viewer">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                    <dependencies>
                        <dependency type="enable" setting="enable_log" expression="true"/>
                    </dependencies>
                </setting>
                <setting id="log_level" type="integer" label="Log Level">
                    <level>0</level>
                    <default>1</default>
                    <constraints>
                        <options>
                            <option label="Debug">0</option>
                            <option label="Info">1</option>
                            <option label="Warning">2</option>
                            <option label="Error">3</option>
                        </options>
                    </constraints>
                    <control type="list" format="integer"/>
                    <dependencies>
                        <dependency type="enable" setting="enable_log" expression="true"/>
                    </dependencies>
                </setting>
                <setting id="log_path" type="path" label="Log Folder">
                    <level>1</level>
                    <default>special://profile/addon_data/script.service.flaresolverr/</default>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="button" format="path"/>
                </setting>
            </group>
        </category>
    </section>
</settings>
